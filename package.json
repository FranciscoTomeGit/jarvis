{
  "name": "jarvis",
  "version": "1.0.0",
  "description": "J.A.R.V.I.S. — Personal AI Desktop Assistant",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.jarvis.assistant",
    "productName": "JARVIS",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico"
    },
    "extraResources": [
      { "from": "backend",      "to": "backend"      },
      { "from": "frontend",     "to": "frontend"     },
      { "from": "data",         "to": "data"         },
      { "from": "run.py",       "to": "run.py"       },
      { "from": "requirements.txt", "to": "requirements.txt" }
    ]
  }
}
